# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values. NEVER commit your `.env`.
# ---------------------------------------------------------------------------

# --- Foundry project ---
# Get this from the Foundry portal: your project -> Overview -> Project connection string
AZURE_AI_PROJECT_CONNECTION_STRING=eastus2.api.azureml.ms;<subscription-id>;<rg>;<project>

# Deployment name of the model you created in Foundry (e.g. gpt-4o, gpt-4.1)
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- Azure AI Search (Challenge 2) ---
AZURE_SEARCH_ENDPOINT=https://<search-name>.search.windows.net
AZURE_SEARCH_INDEX=idx-clm-contracts
AZURE_SEARCH_API_KEY=<optional-if-not-using-managed-identity>

# --- Tools (Challenge 3) ---
# Power Automate HTTP-triggered flow for approval routing
POWER_AUTOMATE_APPROVAL_URL=https://prod-XX.westus.logic.azure.com:443/workflows/<flow-id>/triggers/manual/paths/invoke?api-version=2016-06-01&sp=...&sig=...
# SharePoint site + document library backing the Contract Repository tool
SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/LegalContractRepository
SHAREPOINT_LIBRARY_TEMPLATES=Templates
SHAREPOINT_LIBRARY_EXECUTED=Executed Contracts
# Dataverse environment (or Azure SQL connection) for the Contract Status tool
DATAVERSE_ENVIRONMENT_URL=https://<org>.crm.dynamics.com
DATAVERSE_TABLE=clm_contracts
# Optional Azure SQL fallback if you're not using Dataverse
AZURE_SQL_CONNECTION_STRING=

# --- Observability (Challenge 5) ---
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

# --- Deployment (Challenge 8) ---
WEBAPP_URL=https://<webapp>.azurewebsites.net
API_ENDPOINT_URL=https://<api-endpoint>.inference.ai.azure.com

# --- Optional: local overrides ---
LOG_LEVEL=INFO
